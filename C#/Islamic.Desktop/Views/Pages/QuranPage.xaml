<UserControl x:Class="IslamicDesktop.Views.Pages.QuranPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F3EE">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel HorizontalAlignment="Center"
                        Margin="20">

                <!-- SURAH SELECTOR -->
                <ComboBox x:Name="SurahSelector"
                          Width="250"
                          Margin="0,10,0,20"
                          SelectionChanged="SurahSelector_Changed"/>

                <!-- QURAN CONTAINER -->
                <Border Background="White"
                        Padding="30"
                        CornerRadius="12"
                        BorderBrush="#D8CFC0"
                        BorderThickness="1"
                        MaxWidth="900"
                        HorizontalAlignment="Center">

                    <TextBlock x:Name="QuranTextBlock"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="34"
                               LineHeight="34"
                               FontFamily="Scheherazade New"/>
                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</UserControl>