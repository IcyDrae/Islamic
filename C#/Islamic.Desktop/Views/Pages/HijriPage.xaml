<UserControl x:Class="IslamicDesktop.Views.Pages.HijriPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F3EE">

        <StackPanel HorizontalAlignment="Center"
                    Margin="30">

            <TextBlock x:Name="MonthTitle"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#0F3D3E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <UniformGrid x:Name="CalendarGrid"
                         Columns="7"
                         HorizontalAlignment="Center"/>

            <TextBlock x:Name="RamadanInfo"
                       FontSize="16"
                       Foreground="#555"
                       Margin="0,20,0,0"
                       HorizontalAlignment="Center"/>

            <Border Margin="20,30,20,0"
                    Padding="15"
                    CornerRadius="10"
                    Background="#FFF7E6"
                    BorderBrush="#C9A24A"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Ramadan Info"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#0F3D3E"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="RamadanText"
                               FontSize="16"
                               Foreground="#333"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </Grid>
</UserControl>