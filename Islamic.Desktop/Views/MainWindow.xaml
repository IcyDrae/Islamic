<Window x:Class="IslamicDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Islamic Dashboard"
        WindowState="Maximized">

    <Window.Resources>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E6E1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="6">

                            <ContentPresenter Margin="10,5"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E5B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C9A24A"/>
                                <Setter Property="Foreground" Value="#0F3D3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <StackPanel x:Name="MenuPanel" Background="#123B3A"
            Width="220">

            <TextBlock Text="Islamic"
               Foreground="#C9A24A"
               FontSize="20"
               FontWeight="Bold"
               Margin="15"/>

            <Button Content="Prayer Times" Tag="Prayer" Click="Prayer_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Tomorrow's Prayers" Tag="Tomorrow" Click="Tomorrow_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Dhikr" Tag="Dhikr" Click="Dhikr_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Quran" Tag="Quran" Click="Quran_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Hijri Calendar" Tag="Hijri" Click="Hijri_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="Fasting Days" Tag="Fasting" Click="Fasting_Click" Style="{StaticResource MenuButtonStyle}"/>
            <Button Content="99 Names" Tag="Names" Click="Names_Click" Style="{StaticResource MenuButtonStyle}"/>

        </StackPanel>

        <!-- MAIN CONTENT -->
        <ContentControl x:Name="MainContent"
                Grid.Column="1"
                Background="#F5F3EE"
                Padding="20"/>
    </Grid>
</Window>