<UserControl x:Class="IslamicDesktop.Views.Pages.DhikrPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="#F5F3EE">

        <StackPanel Width="800" Margin="30">

            <TextBlock Text="Dhikr"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#0F3D3E"
                       Margin="0,0,0,20"/>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="DhikrText"
                           FontSize="16"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>