<UserControl x:Class="IslamicDesktop.Views.Pages.FastingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F3EE">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <Border Width="800"
                    Margin="30"
                    Padding="25"
                    Background="White"
                    CornerRadius="12"
                    HorizontalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Fasting Days"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#0F3D3E"
                               Margin="0,0,0,20"/>

                    <TextBlock x:Name="FastingText"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Foreground="#333"/>

                </StackPanel>

            </Border>

        </ScrollViewer>
    </Grid>
</UserControl>