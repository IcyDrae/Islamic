<UserControl x:Class="IslamicDesktop.Views.Pages.PrayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="#F5F3EE">

        <StackPanel Width="400" Margin="30">

            <TextBlock Text="Prayer Times"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#0F3D3E"
                       Margin="0,0,0,20"/>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="CityText"
                           FontSize="16"/>
            </Border>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="FajrText"/>
            </Border>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="DhuhrText"/>
            </Border>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="AsrText"/>
            </Border>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="MaghribText"/>
            </Border>

            <Border Background="White"
                    Padding="15"
                    CornerRadius="10"
                    Margin="0,0,0,10">
                <TextBlock x:Name="IshaText"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>